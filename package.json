  "build": {
    "appId": "com.jarvis-os.app",
    "productName": "Jarvis",
    "copyright": "Copyright © 2026 Jarvis OS",
    "directories": {
      "output": "release/"
    },
    "files": [
      "dist/**/*",
      "electron/dist/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "ehtisham5618",
      "repo": "Jarvis-OS",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "LICENSE"
    },
    "extraMetadata": {
      "main": "electron/dist/main.js"
    }
