  "private": true,
  "sideEffects": false,
  "type": "module",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite dev",
    "dev:electron": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"npm run dev\" \"wait-on http://localhost:8080 && npm run electron:start\"",
    "electron:start": "cross-env NODE_ENV=development electron electron/dist/main.js",
    "electron:build-main": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('electron/dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "build:electron": "npm run build && npm run electron:build-main && electron-builder",
    "build:electron:dir": "npm run build && npm run electron:build-main && electron-builder --dir",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
